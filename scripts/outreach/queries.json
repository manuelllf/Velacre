{
  "_comment": "Configuración del pipeline de research outreach Velacre. Editable sin tocar los scripts.",
  "prefilter": {
    "_comment": "Filtro barato sobre metadata de Google Places antes de gastar en Outscraper.",
    "minUserRatingCount": 150,
    "maxPerQuery": 20
  },
  "buckets": {
    "_comment": "Clasificación por volumen real en últimos 90 días (Outscraper).",
    "discard_max_reviews_90d": 44,
    "core_min_reviews_90d": 45,
    "pro_min_reviews_90d": 90
  },
  "outscraper": {
    "_comment": "60 es suficiente: si el lote llega al límite sin salir de la ventana 90d, se extrapola el ritmo para estimar reviews90d. Más barato (60% menos gasto) y confiable para el bucketing.",
